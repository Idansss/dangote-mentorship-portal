# @vercel/analytics declares optional peers for every framework it supports
# (svelte/@sveltejs/kit, vue, remix…). npm's strict peer resolver tries to
# satisfy the @sveltejs/kit optional peer, which transitively demands Vite 8 and
# conflicts with our Vite 5 (Vitest/Sentry). We use none of those frameworks, so
# relax peer resolution. Keeps local, `npm ci` (CI), and Vercel installs identical.
legacy-peer-deps=true
