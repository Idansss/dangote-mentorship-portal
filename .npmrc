# next-intl@3's peer range predates Next 16 (it declares next ^10..^15), so a
# fresh `npm install` errors with ERESOLVE even though the app builds and runs
# fine on Next 16. Relax peer-dep enforcement until next-intl is upgraded to 4
# (tracked follow-up). Vercel respects this file, so production installs work too.
legacy-peer-deps=true
