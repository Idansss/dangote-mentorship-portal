# ──────────────────────────────────────────────────────────────────────────
# Dangote Mentorship Portal — environment variables (M0)
# Copy to `.env` and fill in. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) ---------------------------------------------------
# Local dev example. For Supabase use the connection-pooler URL for DATABASE_URL
# and the direct URL for DIRECT_URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dangote_mentorship?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dangote_mentorship?schema=public"

# --- Auth.js (NextAuth v5) ---------------------------------------------------
# Generate with: npx auth secret   (or openssl rand -base64 32)
AUTH_SECRET="replace-with-a-32+-byte-random-string"
# Base URL of the app. Required in production; optional in local dev.
AUTH_URL="http://localhost:3000"
# Trust the host header (needed behind some proxies / in containers).
AUTH_TRUST_HOST="true"

# --- Microsoft Entra ID (Azure AD) SSO — primary provider --------------------
# From the App Registration in the Entra admin center.
AUTH_MICROSOFT_ENTRA_ID_ID="00000000-0000-0000-0000-000000000000"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-client-secret-value"
# Use your tenant GUID, or "common" / "organizations" for multi-tenant.
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="00000000-0000-0000-0000-000000000000"

# --- AI (optional in M1; AI features hide themselves when unset) -------------
# Server-side only. Default provider is the Anthropic Messages API.
ANTHROPIC_API_KEY=""
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=""

# --- Email / mail transport --------------------------------------------------
# Microsoft Graph is the mail provider (CLAUDE.md §2). When the four MAIL_GRAPH_*
# vars below are set, lib/mail sends via Graph app-only auth; otherwise it falls
# back to the "log" transport, which prints emails (e.g. the password-reset link)
# to the server log instead of sending them.
# Set to "true" to print full email bodies (incl. reset links) in dev/CI logs.
MAIL_DEBUG="false"
# App registration with the Mail.Send application permission (admin-consented),
# plus the mailbox to send from. Can reuse the SSO app or be a dedicated one.
# The same credentials also drive the Outlook meeting provider (lib/meetings,
# experience-layer.md §1.12): granting the app Calendars.ReadWrite (application)
# lets scheduled meetings push to participants' Outlook calendars. Without that
# permission, scheduling still works — it just won't sync to Outlook.
MAIL_GRAPH_TENANT_ID=""
MAIL_GRAPH_CLIENT_ID=""
MAIL_GRAPH_CLIENT_SECRET=""
MAIL_GRAPH_SENDER="mentorship@dangote.com"

# --- Object storage (agreements/evidence PDFs & attachments) -----------------
# The local-filesystem provider stores files under this dir (outside /public)
# in dev/CI. A Supabase Storage provider slots into lib/storage in production.
STORAGE_LOCAL_DIR=".storage"

# --- Bootstrap / seed --------------------------------------------------------
# Email that the seed grants SUPER_ADMIN to, and the dev fallback password it sets.
SEED_SUPER_ADMIN_EMAIL="admin@dangote.com"
SEED_DEFAULT_PASSWORD="ChangeMe!2026"
