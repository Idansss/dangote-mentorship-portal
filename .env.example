# ──────────────────────────────────────────────────────────────────────────
# Dangote Mentorship Portal — environment variables (M0)
# Copy to `.env` and fill in. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Database (PostgreSQL / Supabase) ----------------------------------------
# Local dev example shown below. For SUPABASE, copy both strings from
# Project Settings → Database → Connection string:
#   DATABASE_URL = the "Transaction" pooler URL (port 6543), used by the app at
#                  runtime. Append `?pgbouncer=true&connection_limit=1`.
#   DIRECT_URL   = the "Session"/direct URL (port 5432), used by Prisma Migrate.
# Example (Supabase):
#   DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dangote_mentorship?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dangote_mentorship?schema=public"

# --- Supabase (Storage now; Realtime in M4) ----------------------------------
# Project URL + keys from Project Settings → API. New-format keys preferred
# (legacy anon/service_role JWTs still work via the *_ANON_KEY/*_SERVICE_ROLE_KEY
# fallbacks). The SECRET key is server-only and grants full access — never expose
# it to the client. Identity stays Auth.js + Entra (CLAUDE.md §2); Supabase Auth
# is NOT used.
NEXT_PUBLIC_SUPABASE_URL=""
# Publishable key (safe in the browser) — used by M4 Realtime channels.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Secret key (server-only) — required for server-side Storage into a private bucket.
SUPABASE_SECRET_KEY=""

# --- Auth.js (NextAuth v5) ---------------------------------------------------
# Generate with: npx auth secret   (or openssl rand -base64 32)
AUTH_SECRET="replace-with-a-32+-byte-random-string"
# Base URL of the app. Required in production; optional in local dev.
AUTH_URL="http://localhost:3000"
# Trust the host header (needed behind some proxies / in containers).
AUTH_TRUST_HOST="true"

# --- Microsoft Entra ID (Azure AD) SSO — primary provider --------------------
# From the App Registration in the Entra admin center.
AUTH_MICROSOFT_ENTRA_ID_ID="00000000-0000-0000-0000-000000000000"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-client-secret-value"
# Use your tenant GUID, or "common" / "organizations" for multi-tenant.
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="00000000-0000-0000-0000-000000000000"

# --- AI (optional in M1; AI features hide themselves when unset) -------------
# Server-side only. Anthropic is the primary provider; OpenAI is an automatic
# fallback used when an Anthropic call fails (bad key, unavailable model, etc.).
# Set either or both; with neither, AI features degrade gracefully.
ANTHROPIC_API_KEY=""
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=""
# OpenAI fallback (used when Anthropic errors, or alone if no Anthropic key).
OPENAI_API_KEY=""
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=""

# --- Email / mail transport --------------------------------------------------
# Microsoft Graph is the mail provider (CLAUDE.md §2). When the four MAIL_GRAPH_*
# vars below are set, lib/mail sends via Graph app-only auth; otherwise it falls
# back to the "log" transport, which prints emails (e.g. the password-reset link)
# to the server log instead of sending them.
# Set to "true" to print full email bodies (incl. reset links) in dev/CI logs.
MAIL_DEBUG="false"
# App registration with the Mail.Send application permission (admin-consented),
# plus the mailbox to send from. Can reuse the SSO app or be a dedicated one.
# The same credentials also drive the Outlook meeting provider (lib/meetings,
# experience-layer.md §1.12): granting the app Calendars.ReadWrite (application)
# lets scheduled meetings push to participants' Outlook calendars. Without that
# permission, scheduling still works — it just won't sync to Outlook.
MAIL_GRAPH_TENANT_ID=""
MAIL_GRAPH_CLIENT_ID=""
MAIL_GRAPH_CLIENT_SECRET=""
MAIL_GRAPH_SENDER="mentorship@dangote.com"

# --- Object storage (agreements/evidence PDFs & attachments) -----------------
# Provider selector: "supabase" or "local". When unset, the app auto-selects
# Supabase if NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are present,
# otherwise the local-filesystem provider. Set "local" to force local even when
# Supabase is configured.
STORAGE_PROVIDER=""
# Private Supabase Storage bucket name (create it in the dashboard; keep it
# PRIVATE — files are confidential, served only via authenticated routes).
SUPABASE_STORAGE_BUCKET="portal-files"
# Local-filesystem provider: stores files under this dir (outside /public) in
# dev/CI when Supabase Storage is not used.
STORAGE_LOCAL_DIR=".storage"

# --- Scheduled jobs (notifications + daily digest) ---------------------------
# Shared secret for the /api/cron/notifications endpoint (experience-layer.md
# §1.10). The scheduler (Vercel Cron, or an on-prem Task Scheduler/systemd timer)
# must call that URL with `Authorization: Bearer <CRON_SECRET>`. When unset, the
# endpoint returns 503 and no scheduled notifications/digests are sent.
CRON_SECRET=""

# --- Error tracking (optional; Sentry) ---------------------------------------
# Fully wired via withSentryConfig (server + edge + browser). Everything no-ops
# until a DSN is set, so dev/CI never phone home. From sentry.io: create a
# project → Settings → Client Keys (DSN).
#   SENTRY_DSN              — server + edge capture (kept server-only).
#   NEXT_PUBLIC_SENTRY_DSN  — browser capture (shipped to the client; usually the
#                             SAME DSN value as SENTRY_DSN).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Trace sample rates (0..1), default 0.1:
# SENTRY_TRACES_RATE=""
# NEXT_PUBLIC_SENTRY_TRACES_RATE=""
# Source-map upload at BUILD time (optional — runtime capture works without it).
# Set all three to get readable stack traces; create the token at
# Sentry → Settings → Auth Tokens (scope: project:releases).
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# --- Shared rate-limit store (optional; Upstash Redis) -----------------------
# Auth + AI rate limiting falls back to a per-process in-memory store, which is
# ineffective across serverless instances. Set both to use a shared, atomic
# store instead (src/lib/auth/rate-limit-shared.ts). Get them from Upstash →
# your Redis DB → REST API.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Bootstrap / seed --------------------------------------------------------
# Email that the seed grants SUPER_ADMIN to, and the dev fallback password it sets.
SEED_SUPER_ADMIN_EMAIL="admin@dangote.com"
SEED_DEFAULT_PASSWORD="ChangeMe!2026"
